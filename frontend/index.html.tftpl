<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>수현님의 맛집 지도</title> <script src="https://cdn.jsdelivr.net/npm/amazon-cognito-identity-js@6.3.7/dist/amazon-cognito-identity.min.js"></script>
    <script type="text/javascript" src="https://dapi.kakao.com/v2/maps/sdk.js?appkey=008785773c36ce63a3340655b913ab62&libraries=services&autoload=false"></script>

    <style>
        body { font-family: "Pretendard", -apple-system, sans-serif; padding: 20px; max-width: 900px; margin: 0 auto; background-color: #f8f9fa; }
        #map { width: 100%; height: 450px; border-radius: 16px; margin-bottom: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 1px solid #eee; }
        .search-container { display: flex; gap: 10px; margin-bottom: 15px; }
        input { flex: 1; padding: 14px; border: 1px solid #dee2e6; border-radius: 10px; font-size: 16px; transition: 0.3s; }
        input:focus { outline: none; border-color: #fee500; box-shadow: 0 0 0 3px rgba(254, 229, 0, 0.2); }
        button { padding: 12px 24px; background-color: #fee500; border: none; border-radius: 10px; cursor: pointer; font-weight: bold; font-size: 16px; transition: 0.2s; }
        button:hover { background-color: #fada00; transform: translateY(-1px); }
        
        #auth-bar { background: white; padding: 15px 20px; margin-bottom: 25px; border-radius: 15px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px rgba(0,0,0,0.03); border: 1px solid #efefef; }
        #placesList { max-height: 180px; overflow-y: auto; background: white; border-radius: 12px; margin-bottom: 20px; padding: 0; border: 1px solid #eee; }
        #placesList li { list-style: none; padding: 12px 18px; border-bottom: 1px solid #f1f3f5; display: flex; justify-content: space-between; align-items: center; }
        #placesList li:last-child { border-bottom: none; }
        
        .detail-box { background: white; padding: 30px; border-radius: 20px; margin-top: 25px; box-shadow: 0 15px 35px rgba(0,0,0,0.05); border: 1px solid #eee; }
        .stats-row { display: flex; gap: 20px; margin: 20px 0; padding: 15px; background: #fffde7; border-radius: 12px; font-weight: 600; align-items: center; color: #5d4037; }
        .review-input-row { display: flex; gap: 10px; margin-top: 20px; background: #f8f9fa; padding: 20px; border-radius: 12px; border: 1px dashed #ced4da; }
        
        ul#reviewList { list-style: none; padding: 0; margin-top: 20px; }
        ul#reviewList li { background: #fff; padding: 18px; margin-bottom: 12px; border-radius: 12px; border-left: 6px solid #fee500; box-shadow: 0 4px 6px rgba(0,0,0,0.02); border-top: 1px solid #f1f3f5; border-right: 1px solid #f1f3f5; border-bottom: 1px solid #f1f3f5; }
    </style>
</head>
<body>

    <div id="auth-bar">
        <span id="user-status" style="font-weight: 600; color: #495057;">접속 중...</span>
        <div>
            <button id="loginBtn" onclick="location.href='https://ap-northeast-2mgf2wnmpr.auth.ap-northeast-2.amazoncognito.com/login?client_id=78d2qsb0hetu4o0bpdqp4ltke1&redirect_uri=https://d21zj2nb0qcp1l.cloudfront.net/&response_type=token&scope=email+openid+profile'">로그인</button>
            <button id="logoutBtn" onclick="logout()" style="display:none; background-color: #adb5bd; color: white;">로그아웃</button>
        </div>
    </div>

    <h2 style="margin-bottom: 25px; color: #212529;">📍 수현님의 맛집 지도</h2>

    <div class="search-container">
        <input type="text" id="keyword" placeholder="가고 싶은 맛집을 검색해 보세요!">
        <button onclick="searchPlaces()">🔍 검색</button>
    </div>

    <ul id="placesList"></ul>
    <div id="map"></div>

    <div class="detail-box" id="detailSection">
        <h3 id="placeTitle" style="margin-top: 0; color: #212529;">💡 장소를 선택해 주세요</h3>
        
        <div class="stats-row">
            <span>⭐ 평균 별점: <span id="avgRating" style="color: #f57f17;">0.0</span></span>
            <span>💬 리뷰: <span id="reviewCount">0</span>개</span>
            <span>❤️ 찜: <span id="bookmarkCount">0</span>회</span>
            <button id="mainBookmarkBtn" onclick="mainToggleBookmark()" style="padding: 8px 16px; font-size: 14px; background: #ff5252; color: white; display:none; border-radius: 8px;">❤️ 찜하기</button>
        </div>

        <div class="review-input-row">
            <input type="text" id="content" placeholder="맛은 어떠셨나요? 리뷰를 남겨주세요.">
            <input type="number" id="rating" placeholder="별점(1-5)" min="1" max="5" style="width: 100px;">
            <button onclick="submitReview()" style="background: #28a745; color: white; white-space: nowrap;">등록</button>
        </div>

        <ul id="reviewList"><li>장소를 클릭하면 상세 정보를 볼 수 있습니다.</li></ul>
    </div>

    <script>
        // 1. API 주소 설정 (CloudFront를 통한 /api 호출 권장)
        // 만약 도메인 연결 전이라면 API Gateway의 스테이지 URL을 넣으세요.
        const BASE_URL = "${api_url}"; 
        const RESTAURANT_API_URL = `${BASE_URL}/restaurants`;
        const REVIEWS_API_URL = `${BASE_URL}/reviews`;
        const BOOKMARK_API_URL = `${BASE_URL}/bookmarks`;
        
        const POOL_DATA = {
            UserPoolId: "ap-northeast-2_MGf2wnMpR",
            ClientId: "78d2qsb0hetu4o0bpdqp4ltke1"
        };
        const userPool = new AmazonCognitoIdentity.CognitoUserPool(POOL_DATA);

        let map, ps, infowindow;
        let currentPlace = null;
        let loggedInUserId = "guest_user";

        window.onload = function() {
            checkAuth();
        };

        // 2. 인증 로직
        function parseJwt(token) {
            try {
                const base64Url = token.split(".")[1];
                const base64 = base64Url.replace(/-/g, "+").replace(/_/g, "/");
                return JSON.parse(decodeURIComponent(atob(base64).split("").map(c => "%" + ("00" + c.charCodeAt(0).toString(16)).slice(-2)).join("")));
            } catch (e) { return null; }
        }

        function checkAuth() {
            const hash = window.location.hash;
            if (hash && hash.includes("id_token=")) {
                const params = new URLSearchParams(hash.substring(1));
                const idToken = params.get("id_token");
                if (idToken) {
                    const decoded = parseJwt(idToken);
                    if (decoded) {
                        loggedInUserId = decoded["email"] || decoded["cognito:username"];
                        updateAuthUI(true, loggedInUserId);
                        window.history.replaceState({}, document.title, window.location.pathname);
                        return;
                    }
                }
            }

            const cognitoUser = userPool.getCurrentUser();
            if (cognitoUser != null) {
                cognitoUser.getSession((err, session) => {
                    if (!err && session.isValid()) {
                        const idToken = session.getIdToken().getJwtToken();
                        const decoded = parseJwt(idToken);
                        loggedInUserId = decoded["email"] || decoded["cognito:username"];
                        updateAuthUI(true, loggedInUserId);
                    } else { updateAuthUI(false); }
                });
            } else { updateAuthUI(false); }
        }

        function updateAuthUI(isLoggedIn, userId = "") {
            const statusEl = document.getElementById("user-status");
            const loginBtn = document.getElementById("loginBtn");
            const logoutBtn = document.getElementById("logoutBtn");

            if (isLoggedIn) {
                statusEl.innerText = `👋 ${userId}님, 반갑습니다!`;
                loginBtn.style.display = "none";
                logoutBtn.style.display = "inline-block";
            } else {
                statusEl.innerText = "로그인이 필요한 서비스입니다.";
                loginBtn.style.display = "inline-block";
                logoutBtn.style.display = "none";
                loggedInUserId = "guest_user";
            }
        }

        function logout() {
            const cognitoUser = userPool.getCurrentUser();
            if (cognitoUser) cognitoUser.signOut();
            alert("정상적으로 로그아웃 되었습니다.");
            location.reload();
        }

        // 3. 지도 로직
        kakao.maps.load(() => {
            const container = document.getElementById("map");
            map = new kakao.maps.Map(container, { center: new kakao.maps.LatLng(37.5665, 126.9780), level: 3 });
            ps = new kakao.maps.services.Places(); 
            infowindow = new kakao.maps.InfoWindow({ zIndex: 1 });
            kakao.maps.event.addListener(map, "click", () => infowindow.close());
            displayMarkers();
        });

        async function displayMarkers() {
            try {
                const res = await fetch(RESTAURANT_API_URL);
                if (!res.ok) return;
                const data = await res.json();
                if (Array.isArray(data)) {
                    data.forEach(place => {
                        const marker = new kakao.maps.Marker({ map: map, position: new kakao.maps.LatLng(place.lat, place.lng) });
                        kakao.maps.event.addListener(marker, "click", () => openInfoWindow(marker, place.place_id, place.name, place.lat, place.lng));
                    });
                }
            } catch (e) { console.error("마커 로딩 에러:", e); }
        }

        function searchPlaces() {
            const keyword = document.getElementById("keyword").value;
            if (!keyword.trim()) return alert("검색어를 입력해 주세요!");
            ps.keywordSearch(keyword, (data, status) => {
                if (status === kakao.maps.services.Status.OK) {
                    const listEl = document.getElementById("placesList");
                    listEl.innerHTML = ""; 
                    const bounds = new kakao.maps.LatLngBounds();
                    data.forEach(place => {
                        const li = document.createElement("li");
                        li.innerHTML = `<span><strong>${place.place_name}</strong> <br><small style="color:#888">${place.address_name}</small></span><button onclick="selectPlace('${place.id}', '${place.place_name}', ${place.y}, ${place.x}, '${place.address_name}', '${place.category_group_name}')" style="padding: 5px 10px; font-size: 13px;">선택</button>`;
                        listEl.appendChild(li);
                        bounds.extend(new kakao.maps.LatLng(place.y, place.x));
                    });
                    map.setBounds(bounds);
                }
            });
        }

        function openInfoWindow(marker, id, name, lat, lng) {
            infowindow.setContent(`<div style="padding:10px;text-align:center; font-size:14px;"><strong>${name}</strong><br><button onclick="selectPlace('${id}', '${name}', ${lat}, ${lng})" style="margin-top:8px; padding: 4px 10px; background:#fee500; border:none; border-radius:5px; font-weight:bold; cursor:pointer;">상세보기</button></div>`);
            infowindow.open(map, marker);
        }

        async function selectPlace(id, name, lat, lng, address="", category="") {
            currentPlace = { id, name, lat, lng, address, category };
            document.getElementById("placeTitle").innerText = `📍 ${name}`;
            document.getElementById("mainBookmarkBtn").style.display = "inline-block";
            infowindow.close();
            
            await loadReviews(id);
            await loadBookmarksCount(id);
        }

        // 4. API 통신 로직
        async function loadReviews(placeId) {
            try {
                const res = await fetch(`${REVIEWS_API_URL}?place_id=${placeId}`);
                const data = await res.json();
                const list = document.getElementById("reviewList");
                
                if (!Array.isArray(data)) {
                    list.innerHTML = "<li>리뷰 데이터 형식이 올바르지 않습니다.</li>";
                    return;
                }

                list.innerHTML = data.length ? "" : "<li>아직 리뷰가 없네요. 첫 리뷰를 작성해 보세요! ✍️</li>";
                let totalRating = 0;
                data.forEach(item => {
                    totalRating += Number(item.rating);
                    const li = document.createElement("li");
                    li.innerHTML = `<div>${item.content}</div><div style="margin-top:8px; font-size:13px; color:#f57f17; font-weight:bold;">⭐ ${item.rating}점 <span style="color:#adb5bd; margin-left:10px; font-weight:normal;">| ${item.user_id}</span></div>`;
                    list.appendChild(li);
                });
                document.getElementById("reviewCount").innerText = data.length;
                document.getElementById("avgRating").innerText = data.length ? (totalRating / data.length).toFixed(1) : "0.0";
            } catch (e) { console.error("리뷰 로드 실패:", e); }
        }

        async function loadBookmarksCount(placeId) {
            try {
                const res = await fetch(`${BOOKMARK_API_URL}?place_id=${placeId}`);
                const data = await res.json();
                document.getElementById("bookmarkCount").innerText = Array.isArray(data) ? data.length : 0;
            } catch (e) { document.getElementById("bookmarkCount").innerText = "0"; }
        }

        async function mainToggleBookmark() {
            if (!currentPlace) return;
            if (loggedInUserId === "guest_user") return alert("로그인이 필요한 기능입니다! 상단에서 로그인해 주세요.");

            try {
                const response = await fetch(BOOKMARK_API_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        place_id: String(currentPlace.id),
                        user_id: loggedInUserId,
                        name: currentPlace.name,
                        lat: String(currentPlace.lat),
                        lng: String(currentPlace.lng)
                    })
                });
                if (response.ok) {
                    alert("성공적으로 처리되었습니다!");
                    loadBookmarksCount(currentPlace.id);
                }
            } catch (e) { alert("통신 에러가 발생했습니다."); }
        }

        async function submitReview() {
            if (!currentPlace) return alert("장소를 먼저 선택해 주세요!");
            if (loggedInUserId === "guest_user") return alert("로그인 후 리뷰를 남기실 수 있습니다.");

            const content = document.getElementById("content").value;
            const rating = document.getElementById("rating").value;
            if (!content || !rating) return alert("리뷰 내용과 별점을 모두 입력해 주세요!");

            try {
                const response = await fetch(REVIEWS_API_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ 
                        place_id: String(currentPlace.id), 
                        name: currentPlace.name, 
                        lat: String(currentPlace.lat), 
                        lng: String(currentPlace.lng), 
                        address: currentPlace.address,
                        category: currentPlace.category,
                        content, 
                        rating: Number(rating), 
                        user_id: loggedInUserId 
                    })
                });
                if (response.ok) {
                    alert("리뷰가 소중하게 등록되었습니다!");
                    document.getElementById("content").value = "";
                    document.getElementById("rating").value = "";
                    loadReviews(currentPlace.id);
                }
            } catch (e) { alert("리뷰 등록 중 에러가 발생했습니다."); }
        }
    </script>
</body>
</html>